# FirstAid Copilot — voice server (.env) template
#
# 把需要的项复制进本地 .env（server.js 入口会 loadEnv 到 process.env；已有的
# process.env 永远优先，便于命令行覆盖）。本文件不含任何密钥。
#
# 分四组：① 语音引擎（sherpa-onnx STT/TTS） ② Gemma ③ 端侧安全/可观测开关（本次新增）
# ④ 混合 NLU。除非显式打开，所有“安全/可观测”开关默认 OFF，默认行为与裸跑一致。

# ───────────────────────────── ① 语音引擎 ─────────────────────────────
# mock 起步即可跑通 Node demo 链路（无需模型）；模型与命令就绪后切到 sherpa-onnx。
SPEECH_MODE=mock
VOICE_STT_PROVIDER=mock
VOICE_TTS_PROVIDER=mock

# 切到真实语音（取消注释，并确认 setupSpeech.ps1 报告 Python/sherpa-onnx/模型就绪）：
# SPEECH_MODE=sherpa-onnx
# VOICE_STT_PROVIDER=sherpa-onnx
# VOICE_TTS_PROVIDER=sherpa-onnx
# SPEECH_DAEMON=1                 # 常驻 STT/TTS 进程，复用以降低每轮冷启延迟
# SPEECH_TTS_STREAM=1             # Live WS 用常驻 sherpa_tts_stream.py 真流式合成（首块边合边播）

SHERPA_ONNX_STT_COMMAND=python
SHERPA_ONNX_STT_ARGS=scripts/speech/sherpa_stt.py --model-dir "{model_dir}" --audio "{audio}" --language "{language}"
SHERPA_ONNX_TTS_COMMAND=python
SHERPA_ONNX_TTS_ARGS=scripts/speech/sherpa_tts.py --model-dir "{model_dir}" --output "{out}" --text "{text}"
SPEECH_STT_MODEL_DIR=models/speech/stt
SPEECH_TTS_MODEL_DIR=models/speech/tts
# Live 麦克风走流式 zipformer（HTTP 录音回退走上面的 SenseVoice 批式）：
SPEECH_STT_STREAM_MODEL_DIR=models/speech/stt-stream

SPEECH_SAMPLE_RATE=16000
SPEECH_LANGUAGE=auto
VOICE_STT_TIMEOUT_MS=60000
VOICE_TTS_TIMEOUT_MS=60000

# 流式 STT 端点（断句）：RULE2 是“说完后尾随静音(秒)”，太小会半句切断。默认 0.8，
# 仍偏紧可调 1.0–1.2；RULE1 为首次出声前静音；RULE3 强切过长句。
SPEECH_STT_STREAM_RULE1_MIN_TRAILING_SILENCE=2.4
SPEECH_STT_STREAM_RULE2_MIN_TRAILING_SILENCE=0.8
SPEECH_STT_STREAM_RULE3_MIN_UTTERANCE_LENGTH=20

# ───────────────────────────── ② Gemma ─────────────────────────────
# Gemma 不在语音热路径：保守关常驻 + 短超时，超时即回退状态机话术。
GEMMA_DAEMON=0
GEMMA_BACKEND=cpu
GEMMA_TURN_TIMEOUT_MS=1000
GEMMA_LIVE_TIMEOUT_MS=1200

# ──────────────── ③ 端侧安全 / 可观测开关（本次新增，默认 OFF）────────────────
# STT final 复核：命中“呼吸/否定”关键词的流式 final 触发一次异构离线 STT（SenseVoice）
# 复核纠偏（流式 zipformer 把“没有呼吸”听成“有呼吸”是最致命误判）。代价是关键回合多
# 一次离线识别延迟，因此只对关键 final 触发、且默认关闭。
STT_FINAL_REVIEW=off

# barge-in 服务端能量门控：作为客户端 VAD 的兜底（外放/嘈杂环境双保险）。默认 OFF
# （客户端显式 barge_in 始终是主路径）。打开后可用下面两项做真机调参。
VOICE_BARGE_IN_ENERGY_GATE=off
# VOICE_BARGE_IN_RMS=0.18           # 触发门控的 RMS 阈值（0~1），越高越不易误触发
# VOICE_BARGE_IN_MIN_SPEECH_MS=200  # 需持续超阈值多少毫秒才判为打断

# 仲裁审计日志：打印每轮 guidance 仲裁来源/原因，便于排查话术为何被选中/拦截。
# GUIDANCE_AUDIT_LOG=on

# 其它运行参数：
# VOICE_HOST=127.0.0.1
# VOICE_PORT=8787
# VOICE_EVENT_TTL_MS=5000           # 感知事件过期窗口
# VOICE_TTS_CACHE_DIR=assets/tts_cache   # 预渲染 TTS 缓存目录（命中即跳过实时合成）
#
# 可观测性：Live WS 每轮已 emit `metrics` 事件；服务端聚合见 GET /api/metrics
# （延迟 p50/p95、TTS 缓存命中率、intent 回退分布、gemma skip/stale、复核纠偏计数）。
# 该接口无需开关，随 voice:serve 默认可用。

# ───────────────────────────── ④ 混合 NLU ─────────────────────────────
# INTENT_NLU=on 让模糊语料走本地 Gemma 槽位抽取；off 则纯正则。Live 下为
# “regex_then_async”：本轮先正则即时兜底推进，Gemma 后台异步纠正下一轮，不阻塞回合。
INTENT_NLU=off
GEMMA_NLU_TIMEOUT_MS=600           # 单次 NLU 超时(ms)，超时回退正则
NLU_CACHE=on                       # transcript→NLU 结果短期缓存，避免重复推理
NLU_BUDGET=on                      # 每会话 NLU 调用预算，防 S1–S6 频繁 miss 打爆 CPU
NLU_BUDGET_MAX_CALLS=12
NLU_BUDGET_WINDOW_MS=60000
