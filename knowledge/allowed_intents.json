      "restricted": [
        "start_emergency_call",
        "start_emergency_call_and_cpr",
        "attach_gps",
        "start_local_recording"
      ]
    },
    "S6_CPR_READY": {
      "autonomy": ["answer_position_question", "encourage_rescuer"],
      "restricted": [
        "guide_cpr_position",
        "start_cpr_guidance",
        "start_cpr_loop",
        "step_done",
        "compressions_reported"
      ]
    },
    "S7_CPR_LOOP": {
      "autonomy": ["answer_current_cpr_question", "encourage_rescuer", "calm_rescuer"],
      "restricted": [
        "correction.hand_position",
        "correction.rate_low",
        "correction.rate_high",
        "correction.arm_bent",
        "correction.interruption",
        "continue_cpr",
