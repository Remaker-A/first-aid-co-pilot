  "gemma_decision_scope_principle": "Tier-2 授权信封：每阶段把意图二分为 autonomy（Gemma 可自选 intent + 自由措辞 + 调语气）与 restricted（仅可润色同 intent，不可换义）。仲裁时按状态机选定的 intent 的 scope 决定是否放开 allowIntentChange：restricted 只润色；autonomy 轮允许 Gemma 在该阶段 autonomy 子集内自选。未显式列出的意图按 restricted 从严处理。",
  "gemma_decision_scope": {
    "S0_INIT": {
      "autonomy": ["reassure_rescuer"],
      "restricted": ["session_started", "check_permissions", "start_recording"]
    },
    "S1_SCENE_SAFE": {
      "autonomy": ["reassure_rescuer"],
      "restricted": [
        "ask_scene_safety",
        "scene_safe_confirmed",
        "scene_safe",
        "scene_unsafe",
        "adult_likely",
        "not_adult",
        "warn_scene_danger",
        "ensure_scene_safe",
        "warn_scene_unsafe"
      ]
    },
    "S2_CHECK_RESPONSE": {
      "autonomy": ["reassure_rescuer"],
      "restricted": [
