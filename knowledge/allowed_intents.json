        "monitor_breathing_patient",
        "monitor_after_rosc"
      ]
    },
    "S4_SUSPECTED_ARREST": {
      "autonomy": [],
      "restricted": [
        "state_suspected_arrest_handling",
        "prepare_emergency_call",
        "start_emergency_call_and_cpr"
      ]
    },
    "S5_CALL_EMERGENCY": {
