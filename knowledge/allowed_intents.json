        "compressions_reported",
        "start_cpr_loop",
        "continue_cpr_loop"
      ]
    },
    "S8_ASSISTANCE": {
      "autonomy": ["explain_aed_support", "calm_rescuer", "assist_rescuer_fatigue"],
      "restricted": ["guide_rescuer_change", "continue_cpr", "assist_aed"]
    },
    "S9_HANDOVER": {
      "autonomy": ["handover_summary_patch", "explain_handover"],
      "restricted": ["generate_handover_report", "request_share_report", "request_share_video"]
