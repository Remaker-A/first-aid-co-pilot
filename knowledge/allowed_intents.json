{
  "knowledge_version": "adult_cpr_mvp_2026_06_02",
  "schema_version": "allowed_intents.v0.2",
  "language": "zh-CN",
  "scope": {
    "scenario": "adult_suspected_cardiac_arrest_cpr",
    "principle": "单一来源：Gemma 只能在当前 stage 的 gemma_intents_by_stage 内生成 GuidanceActionPatch。decisionFrame 用它告知 Gemma，actionValidator 用它校验 Gemma，两者必须一致。"
  },
  "intent_defaults": {
