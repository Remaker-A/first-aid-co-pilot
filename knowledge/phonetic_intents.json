{
  "schema_version": "phonetic_intents.v1",
  "knowledge_version": "adult_cpr_mvp_2026_05_30",
  "language": "zh-CN",
  "description": "CPR-live (S6-S8) 音近容错的共享闭集词表。仅在正则意图分类 miss 且处于 CPR-live 时作为安全网，把被听岔的少数关键提问（除颤仪/能否停/呼叫120）拉回固定安全答句。声母+韵母、忽略声调；字表只覆盖关键词、触发后缀所含汉字及其常见同音/音近字，绝不引入完整拼音库。桌面 (src/voice/phoneticIntent.js) 与端侧 (LivePhoneticIntentRouter.kt) 读同一份。",
  "stages": ["S6_CPR_READY", "S7_CPR_LOOP", "S8_ASSISTANCE"],
  "match": {
    "max_keyword_cost": 0.2,
    "max_trigger_cost": 0.34,
    "min_score": 0.7,
    "min_keyword_syllables": 2,
    "max_syllable_cost": 0.5,
    "initial_weight": 0.4,
    "final_weight": 0.6,
    "confusable_initials": [
      ["zh", "z"],
      ["ch", "c"],
      ["sh", "s"],
      ["ch", "sh"],
      ["n", "l"],
      ["f", "h"],
      ["l", "r"],
      ["r", "y"]
    ],
    "confusable_finals": [
      ["an", "ang"],
      ["en", "eng"],
      ["in", "ing"],
      ["ian", "iang"],
      ["uan", "uang"],
      ["n", "ng"],
      ["an", "ai"],
      ["ei", "ui"]
    ]
  },
  "intents": [
    {
      "intent": "aed_available",
      "comment": "AED/除颤仪到达事实。包含『心脏起搏器』这类现场口误，只在 CPR-live 阶段作为软识别；系统播报时应校正为 AED/自动体外除颤器。",
      "require_trigger": true,
      "keywords": ["除颤仪", "除颤器", "除颤", "电击器", "自动体外除颤", "心脏起搏器", "起搏器"],
      "triggers": ["来了", "到了", "拿来了", "取来了", "送来了"]
    },
    {
      "intent": "ask_aed_cpr_alternation",
      "comment": "AED 与按压如何交替/配合。需同时听到 AED/除颤器械词与交替类后缀，只作为 CPR-live 闭集安全问答兜底。",
      "require_trigger": true,
      "keywords": ["除颤仪", "除颤器", "除颤", "电击器", "自动体外除颤"],
      "triggers": ["交替", "怎么交替", "配合", "怎么配合", "轮换"]
    },
    {
      "intent": "ask_aed_help",
      "comment": "除颤仪/AED 协助。正则已覆盖 aed/除颤仪/出差[一姨仪疑] 等；这里补被听成『出差移/出柴疑』之类（韵尾走偏、同音字超出枚举）的情况，需同时听到器械词与一个提问后缀，保证精确率。",
      "require_trigger": true,
      "keywords": ["除颤仪", "除颤器", "除颤", "电击器", "自动体外除颤"],
      "triggers": ["来了", "到了", "怎么办", "怎么用", "怎么做", "在哪", "拿来了"]
    },
    {
      "intent": "ask_can_stop",
      "comment": "能不能停止按压。正则已覆盖 能不能停/能不能听/可以停 等；这里补被听成『能不能婷/可以挺』之类。仅保留 >=3 音节的自足问句形态，require_trigger=false。",
      "require_trigger": false,
      "keywords": ["能不能停", "可以停了", "可以停", "要不要停", "还要按多久", "按到什么时候"],
      "triggers": []
    },
    {
      "intent": "ask_emergency_call",
      "comment": "是否需要呼叫 120。正则用 120 数字 + 要不要/打吗 等；数字转写较稳，这里补『急救电话』被听岔的情况，须同时有提问后缀。",
      "require_trigger": true,
      "keywords": ["急救电话", "打急救电话"],
      "triggers": ["要不要", "需不需要", "打吗", "用不用", "现在打"]
    }
  ],
